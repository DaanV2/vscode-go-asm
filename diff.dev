+    );
+  });
+
+  it("normalizes unix absolute path", () => {
+    assert.strictEqual(
+      normalizePathForCompare("/home/me/work/pkg/foo.go"),
+      "home/me/work/pkg/foo.go",
+    );
+  });
 });
